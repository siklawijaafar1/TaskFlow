# ══════════════════════════════════════════════════════════════════════════════
# TaskFlow — variables d'environnement
# Copier ce fichier en .env et remplir chaque valeur.
# Ne jamais committer le fichier .env (voir .gitignore).
# ══════════════════════════════════════════════════════════════════════════════

# ── Serveur ───────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
API_PREFIX=/api/v1

# ── Base de données (dev) ─────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=taskflow_dev
DB_USER=postgres
DB_PASSWORD=postgres
DB_POOL_MIN=2
DB_POOL_MAX=10

# ── Base de données (test) ────────────────────────────────────────────────────
TEST_DB_HOST=localhost
TEST_DB_PORT=5433
TEST_DB_NAME=taskflow_test
TEST_DB_USER=postgres
TEST_DB_PASSWORD=postgres

# ── Base de données (production) ──────────────────────────────────────────────
# En production, utiliser DATABASE_URL à la place des variables individuelles.
# DATABASE_URL=postgresql://user:password@host:5432/taskflow_prod?sslmode=require

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redispass
REDIS_TTL_SECONDS=3600

# ── JWT ───────────────────────────────────────────────────────────────────────
# Générer avec : node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change_me_in_production_use_64_random_bytes
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# ── Cookies ───────────────────────────────────────────────────────────────────
# Générer avec : node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
COOKIE_SECRET=change_me_in_production_use_32_random_bytes
COOKIE_SECURE=false      # true en production (HTTPS obligatoire)
COOKIE_SAME_SITE=Strict

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:5173

# ── Frontend (Vite) ───────────────────────────────────────────────────────────
VITE_API_BASE_URL=http://localhost:3000/api/v1

# ── pgAdmin (docker-compose.dev.yml) ─────────────────────────────────────────
PGADMIN_EMAIL=admin@taskflow.local
PGADMIN_PASSWORD=admin
PGADMIN_PORT=5050

# ── Logs ──────────────────────────────────────────────────────────────────────
LOG_LEVEL=info          # debug | info | warn | error
